# Reusable SvelteKit + Cloudflare client site template configuration
name = "generalize-landing-template"
compatibility_date = "2026-06-30"
compatibility_flags = [ "nodejs_compat" ]
pages_build_output_dir = ".svelte-kit/cloudflare"

[vars]
# Public environment variables (non-sensitive)
PUBLIC_SITE_URL = "https://client-site.pages.dev"

[[d1_databases]]
binding = "DB"
database_name = "client_db"
database_id = "PLACEHOLDER_D1_DATABASE_ID"
migrations_dir = "drizzle"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "client-assets-bucket"
preview_bucket_name = "client-assets-bucket"
