# Required secrets (copy to .dev.vars for local development)
# HMAC key for admin session signatures, minimum 32 bytes of high entropy
ADMIN_SESSION_SECRET="DEVELOPMENT_SESSION_SECRET_CHANGE_THIS_IN_PRODUCTION"

# Zoho ZeptoMail API Token
ZEPTOMAIL_API_KEY="your_zeptomail_api_token"
# Bounce address configured in Zoho, e.g. bounce@bounce.yourdomain.com
ZEPTOMAIL_BOUNCE_EMAIL="bounce@bounce.yourdomain.com"

# Web Push / VAPID (admin browser push notifications)
# Generate with: node --input-type=module << 'EOF'
#   import { subtle } from 'node:crypto';
#   const pair = await subtle.generateKey({ name: 'ECDSA', namedCurve: 'P-256' }, true, ['sign', 'verify']);
#   const priv = await subtle.exportKey('jwk', pair.privateKey);
#   const pub = Buffer.from(await subtle.exportKey('raw', pair.publicKey)).toString('base64url');
#   console.log('VAPID_PUBLIC_KEY=' + pub);
#   console.log('VAPID_PRIVATE_KEY_JWK=' + JSON.stringify(priv));
# EOF
VAPID_PUBLIC_KEY="base64url-encoded-uncompressed-P256-public-key"
VAPID_PRIVATE_KEY_JWK='{"kty":"EC","crv":"P-256","d":"...","x":"...","y":"..."}'
# Use mailto: or an https: URL — required by Web Push spec
VAPID_SUBJECT="mailto:admin@yourdomain.com"
